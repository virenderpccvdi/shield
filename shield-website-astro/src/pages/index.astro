---
// Shield home page — Astro version
// This is the proof-of-concept Astro port of shield-website/index.html.
// It uses BaseLayout (shared head/fonts/meta), SiteNav, SiteFooter.
// Page-specific hero, features, pricing, testimonials are inline.
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="Shield — Protect Your Family's Digital World"
  description="Shield gives parents complete control over their children's internet. DNS filtering on 4G & WiFi, screen time schedules, real-time alerts, GPS tracking — Android parental controls."
  canonical="https://shield.rstglobal.in/"
>
  <Fragment slot="head">
    <meta name="keywords" content="parental control app, dns filtering, screen time control, internet safety kids, family internet protection, parental controls android"/>
    <script is:inline type="application/ld+json">
    {"@context":"https://schema.org","@type":"MobileApplication","name":"Shield — Family Internet Protection","operatingSystem":"Android 7.0+","applicationCategory":"UtilitiesApplication","offers":{"@type":"Offer","price":"0","priceCurrency":"INR"},"publisher":{"@type":"Organization","name":"RST Global","url":"https://shield.rstglobal.in"}}
    </script>
    {/* Page-specific styles loaded here — keeps BaseLayout generic */}
    <link rel="stylesheet" href="/home.css"/>
  </Fragment>

  <SiteNav />

  <main id="main">
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <div data-reveal>
            <div class="badge badge-outline-white" style="margin-bottom: var(--s-5);">
              <span class="badge-dot"></span>
              Protecting 50,000+ families
            </div>
            <h1>Protect your<br/>family's <span>digital world</span></h1>
            <p class="hero-sub">
              Shield wraps every Android phone and tablet in a layer of intelligent protection.
              Block harmful content, enforce healthy screen limits, and stay connected to your family wherever they are.
            </p>
            <div class="hero-ctas">
              <a href="/register" class="btn btn-white btn-lg">
                Start free
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="#download" class="btn btn-outline-white btn-lg">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 16l-4-4h3V4h2v8h3l-4 4z"/><path d="M20 18H4v2h16v-2z"/></svg>
                Download app
              </a>
            </div>
            <div class="hero-trust">
              <div class="hero-trust-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                No credit card
              </div>
              <div class="hero-trust-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                14-day trial
              </div>
              <div class="hero-trust-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Cancel anytime
              </div>
            </div>
          </div>
          <div class="hero-phone-wrap" data-reveal data-reveal-delay="2" aria-hidden="true">
            <div class="phone">
              <div class="phone-notch"></div>
              <div class="phone-screen">
                <div class="phone-row">
                  <div class="phone-card">
                    <div class="phone-card-label">Screen Time</div>
                    <div class="phone-card-val">2h 14m</div>
                    <div class="phone-card-sub">Today · limit 4h</div>
                  </div>
                  <div class="phone-card">
                    <div class="phone-card-label">Blocked</div>
                    <div class="phone-card-val">137</div>
                    <div class="phone-card-sub">This week</div>
                  </div>
                </div>
                <div class="phone-alert">
                  <div class="phone-alert-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div class="phone-alert-text">
                    <span class="phone-alert-title">Safe browsing active</span>
                    Filters running on 4G &amp; WiFi
                  </div>
                </div>
                <div class="phone-bar">
                  <div class="phone-bar-label">Daily limit — 62% used</div>
                  <div class="phone-bar-track"><div class="phone-bar-fill"></div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="features" id="features">
      <div class="container">
        <div class="section-header" data-reveal>
          <span class="section-eyebrow">What Shield does</span>
          <h2 class="section-title">Everything your family needs, in one app</h2>
          <p class="section-subtitle">A complete digital safety platform for modern families — works on any Android device, any network.</p>
        </div>
        <div class="features-grid">
          {[
            { icon: 'M12 2L3 8v6c0 5.25 3.75 10.15 9 11.35C17.25 24.15 21 19.25 21 14V8L12 2z', title: 'Works everywhere', desc: 'DNS-level content filtering blocks harmful websites across all apps — on WiFi, school networks, and mobile 4G/5G simultaneously.' },
            { icon: 'M12 2a10 10 0 100 20 10 10 0 000-20z|M12 6v6l4 2', title: 'Smart schedules', desc: 'Daily time budgets, bedtime lockdowns, and per-app limits. Healthy digital habits built in, adjustable any time.' },
            { icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z|M12 10m-3 0a3 3 0 106 0 3 3 0 10-6 0', title: 'Live location', desc: 'Real-time GPS tracking with geofence alerts. Know when your child arrives at school or leaves a safe zone.' },
            { icon: 'M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9|M13.73 21a2 2 0 01-3.46 0', title: 'Instant alerts', desc: 'Know the moment your child tries to access blocked content or leaves a safe zone. Push notifications on your phone.' },
            { icon: 'M12 2a10 10 0 100 20 10 10 0 000-20z|M12 8v4l3 2|M7 20l1-3M17 20l-1-3', title: 'Family controls', desc: 'Manage multiple children from one dashboard. Set per-child rules, filters, and schedules that adapt as they grow.' },
            { icon: 'M12 2l3 6.5 7 .8-5 4.8 1.2 6.9L12 17.8 5.8 21 7 14.1 2 9.3l7-.8L12 2', title: 'Rewards system', desc: 'Motivate good behaviour with a points engine. Children earn stars for respecting screen time and completing tasks.' },
          ].map((f, i) => (
            <div class="feature-card" data-reveal data-reveal-delay={String((i % 3) + 1)}>
              <div class="feature-icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  {f.icon.split('|').map(d => <path d={d}/>)}
                </svg>
              </div>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="how" id="how-it-works">
      <div class="container">
        <div class="section-header" data-reveal>
          <span class="section-eyebrow">Getting started</span>
          <h2 class="section-title">Up and running in minutes</h2>
          <p class="section-subtitle">No router configuration. No VPN. Shield is protecting your family the moment it's installed.</p>
        </div>
        <div class="how-steps">
          {[
            { num: '1', title: 'Create your account', desc: 'Sign up in under a minute. Add each child\'s age and Shield calibrates the right protection level automatically.' },
            { num: '2', title: 'Install on the device', desc: 'Download the Shield app on your child\'s Android phone or tablet. One tap activates DNS protection on WiFi and 4G/5G.' },
            { num: '3', title: 'Monitor & adjust', desc: 'Watch the parent dashboard. Instant alerts for anything needing attention. Adjust rules any time, any device.' },
          ].map((s, i) => (
            <div class="how-step" data-reveal data-reveal-delay={String(i + 1)}>
              <div class="how-step-num">{s.num}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="stats">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item" data-reveal><div class="stat-number">50K+</div><div class="stat-label">Families protected</div></div>
          <div class="stat-item" data-reveal data-reveal-delay="1"><div class="stat-number">99.9%</div><div class="stat-label">Uptime SLA</div></div>
          <div class="stat-item" data-reveal data-reveal-delay="2"><div class="stat-number">5★</div><div class="stat-label">Average rating</div></div>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <div class="container">
        <h2 data-reveal>Ready to protect your family?</h2>
        <p data-reveal data-reveal-delay="1">Join thousands of families already using Shield. Start free — no credit card, no commitment.</p>
        <div class="cta-banner-btns" data-reveal data-reveal-delay="2">
          <a href="/register" class="btn btn-white btn-lg">Create free account</a>
          <a href="/download/shield-app.apk" class="btn btn-outline-white btn-lg">Download APK</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script src="/reveal.js" defer is:inline></script>
</BaseLayout>
