---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Shield — Live Location Share"
  description="View a shared live location from Shield family protection."
  canonical="https://shield.rstglobal.in/share"
  noindex={true}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
    <style is:inline>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        font-family: var(--font-body);
        background: var(--ink-50);
        color: var(--ink-900);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      .share-header {
        background:
          radial-gradient(ellipse 80% 60% at 70% 30%, rgba(107,155,245,0.25) 0%, transparent 65%),
          linear-gradient(135deg, var(--brand-900) 0%, var(--brand-700) 100%);
        color: var(--white);
        padding: var(--s-5) var(--s-6);
        display: flex;
        align-items: center;
        gap: var(--s-4);
      }
      .share-logo {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        font-family: var(--font-display);
        font-weight: 800;
        font-size: var(--text-lg);
        color: var(--white);
        text-decoration: none;
        flex-shrink: 0;
      }
      .share-title-group {
        flex: 1;
        min-width: 0;
      }
      .share-title {
        font-family: var(--font-display);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--white);
        display: flex;
        align-items: center;
        gap: var(--s-3);
        flex-wrap: wrap;
      }
      .share-subtitle {
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.75);
        margin-top: 2px;
      }
      .share-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--s-1);
        padding: 2px var(--s-2);
        border-radius: var(--r-full);
        font-size: var(--text-xs);
        font-weight: 600;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.22);
        backdrop-filter: blur(6px);
      }
      .share-live-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--success-600);
        animation: share-live 2s var(--ease-in-out) infinite;
      }
      @keyframes share-live {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.5; }
      }
      .share-refresh {
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: var(--white);
        width: 36px;
        height: 36px;
        border-radius: var(--r-sm);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background var(--d-fast);
        flex-shrink: 0;
      }
      .share-refresh:hover { background: rgba(255, 255, 255, 0.22); }
      #map-wrap {
        flex: 1;
        position: relative;
      }
      #map {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }
      .info-bar {
        background: var(--white);
        padding: var(--s-4) var(--s-6);
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--s-5);
        border-top: 1px solid var(--ink-200);
        box-shadow: 0 -8px 24px -12px rgba(15, 23, 42, 0.08);
      }
      .info-item { min-width: 0; }
      .info-label {
        font-family: var(--font-display);
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--ink-500);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
      }
      .info-value {
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--ink-900);
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .error-state {
        display: none;
        flex: 1;
        align-items: center;
        justify-content: center;
        padding: var(--s-8);
      }
      .error-state.show { display: flex; }
      .error-card {
        max-width: 440px;
        text-align: center;
        background: var(--white);
        padding: var(--s-10) var(--s-8);
        border-radius: var(--r-xl);
        border: 1px solid var(--ink-200);
        box-shadow: var(--shadow-md);
      }
      .error-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--danger-100);
        color: var(--danger-600);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto var(--s-5);
      }
      .error-card h2 {
        font-family: var(--font-display);
        font-size: var(--text-2xl);
        font-weight: 700;
        color: var(--ink-900);
        margin-bottom: var(--s-3);
      }
      .error-card p {
        font-size: var(--text-sm);
        color: var(--ink-600);
        line-height: var(--leading-relaxed);
        margin-bottom: var(--s-6);
      }
      .error-card a {
        display: inline-flex;
        align-items: center;
        gap: var(--s-2);
        padding: 10px var(--s-5);
        background: var(--brand-600);
        color: var(--white);
        text-decoration: none;
        border-radius: var(--r-md);
        font-family: var(--font-display);
        font-weight: 700;
        font-size: var(--text-sm);
        transition: background var(--d-fast);
      }
      .error-card a:hover { background: var(--brand-700); }
      .leaflet-container { background: var(--ink-100); }
      @media (max-width: 720px) {
        .info-bar {
          grid-template-columns: 1fr 1fr;
          gap: var(--s-3);
        }
        .share-title { font-size: var(--text-base); }
        .share-header { padding: var(--s-4); }
      }
    </style>
  </Fragment>

  <header class="share-header">
    <a href="/" class="share-logo" aria-label="Shield home">
      <svg width="30" height="30" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M16 2L4 7V16C4 22.627 9.373 28 16 30C22.627 28 28 22.627 28 16V7L16 2Z" fill="rgba(255,255,255,0.18)"/>
        <path d="M16 5L7 9.5V16C7 21.247 11.029 25.742 16 27.472C20.971 25.742 25 21.247 25 16V9.5L16 5Z" fill="rgba(255,255,255,0.4)"/>
        <path d="M12 16.5L14.5 19L20 13.5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Shield
    </a>
    <div class="share-title-group">
      <div class="share-title">
        Location share
        <span class="share-badge" id="shareBadge">
          <span class="share-live-dot"></span>
          <span id="shareBadgeLabel">Live</span>
        </span>
      </div>
      <div class="share-subtitle" id="headerSubtitle">Loading location...</div>
    </div>
    <button class="share-refresh" id="refreshBtn" aria-label="Refresh location">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M23 4v6h-6M1 20v-6h6"/>
        <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
      </svg>
    </button>
  </header>

  <main id="map-wrap">
    <div id="map"></div>
  </main>

  <section class="info-bar" id="infoBar">
    <div class="info-item">
      <div class="info-label">Child</div>
      <div class="info-value" id="childName">&mdash;</div>
    </div>
    <div class="info-item">
      <div class="info-label">Last updated</div>
      <div class="info-value" id="lastUpdated">&mdash;</div>
    </div>
    <div class="info-item">
      <div class="info-label">Accuracy</div>
      <div class="info-value" id="accuracy">&mdash;</div>
    </div>
    <div class="info-item">
      <div class="info-label">Expires</div>
      <div class="info-value" id="expiresAt">&mdash;</div>
    </div>
  </section>

  <div class="error-state" id="errorState">
    <div class="error-card">
      <div class="error-icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h2>Link unavailable</h2>
      <p id="errorMessage">This location share link has expired or is no longer valid.</p>
      <a href="/">
        Return to Shield
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <script is:inline>
    const pathParts = window.location.pathname.replace(/\/+$/, '').split('/');
    const token = pathParts[pathParts.length - 1];

    let map = null;
    let marker = null;
    let accuracyCircle = null;

    const fmtRelative = (iso) => {
      const d = new Date(iso);
      const minutesAgo = Math.round((Date.now() - d.getTime()) / 60000);
      if (minutesAgo < 2) return 'Just now';
      if (minutesAgo < 60) return minutesAgo + ' min ago';
      const hoursAgo = Math.round(minutesAgo / 60);
      return hoursAgo + ' hr ago';
    };
    const fmtDateTime = (iso) => iso ? new Date(iso).toLocaleString(undefined, {
      month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
    }) : '\u2014';

    function showError(message) {
      document.getElementById('map-wrap').style.display = 'none';
      document.getElementById('infoBar').style.display = 'none';
      document.getElementById('errorState').classList.add('show');
      document.getElementById('errorMessage').textContent =
        message || 'This location share link has expired or is no longer valid.';
    }

    async function loadLocation() {
      if (!token || token === 'share') {
        showError('No share token found in the URL.');
        return;
      }
      try {
        const res = await fetch('/public/location/share/' + encodeURIComponent(token));
        if (res.status === 404) throw new Error('This link does not exist or has already been removed.');
        if (res.status === 410) throw new Error('This location share link has expired.');
        if (!res.ok) throw new Error('Unable to load location data (HTTP ' + res.status + ').');

        const json = await res.json();
        const d = json.data || json;
        if (!d || d.latitude == null || d.longitude == null) {
          throw new Error('Location data is not available at this time.');
        }

        document.getElementById('childName').textContent   = d.name || 'Child';
        document.getElementById('accuracy').textContent    = d.accuracy != null ? Math.round(d.accuracy) + '\u202fm' : 'N/A';
        document.getElementById('expiresAt').textContent   = fmtDateTime(d.expiresAt);
        document.getElementById('lastUpdated').textContent = fmtRelative(d.recordedAt);
        document.getElementById('headerSubtitle').textContent = 'Sharing ' + (d.name || 'child') + "'s live location";
        if (d.shareLabel) document.getElementById('shareBadgeLabel').textContent = d.shareLabel;

        const lat = parseFloat(d.latitude);
        const lng = parseFloat(d.longitude);

        if (!map) {
          map = L.map('map', { zoomControl: true }).setView([lat, lng], 15);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '\u00a9 <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 19
          }).addTo(map);
        }

        const icon = L.divIcon({
          html: '<div style="background:#1E4FC4;width:18px;height:18px;border-radius:50%;border:3px solid white;box-shadow:0 2px 10px rgba(15,23,42,0.35)"></div>',
          className: '',
          iconSize: [18, 18],
          iconAnchor: [9, 9]
        });

        if (marker) marker.setLatLng([lat, lng]);
        else marker = L.marker([lat, lng], { icon }).addTo(map).bindPopup(d.name || 'Child');

        if (d.accuracy != null && d.accuracy > 0) {
          if (accuracyCircle) {
            accuracyCircle.setLatLng([lat, lng]).setRadius(d.accuracy);
          } else {
            accuracyCircle = L.circle([lat, lng], {
              radius: d.accuracy,
              color: '#1E4FC4',
              fillColor: '#3B6FE0',
              fillOpacity: 0.12,
              weight: 1.5
            }).addTo(map);
          }
        }

        map.setView([lat, lng], map.getZoom() || 15);
      } catch (err) {
        showError(err.message);
      }
    }

    document.getElementById('refreshBtn').addEventListener('click', loadLocation);

    if (typeof L !== 'undefined') {
      loadLocation();
    } else {
      window.addEventListener('load', loadLocation);
    }
    setInterval(loadLocation, 30000);
  </script>
</BaseLayout>
